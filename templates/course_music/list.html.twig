<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CourseMusic - Liste</title>
    <style>
        body { font-family: system-ui, sans-serif; margin: 1rem 2rem; color: #111; background: #f5f5f5; }
        h1 { font-size: 1.5rem; margin-bottom: 1rem; }
        .flash-success { margin-bottom: 1rem; padding: 0.5rem 0.75rem; background: #dcfce7; color: #166534; border-radius: 0.5rem; font-size: 0.875rem; }
        .flash-error { margin-bottom: 1rem; padding: 0.5rem 0.75rem; background: #fee2e2; color: #991b1b; border-radius: 0.5rem; font-size: 0.875rem; }
        table { width: 100%; border-collapse: collapse; background: #fff; border: 1px solid #e5e7eb; border-radius: 0.5rem; overflow: hidden; box-shadow: 0 1px 2px rgba(0,0,0,0.05); }
        th, td { padding: 0.5rem 0.75rem; text-align: left; border-bottom: 1px solid #e5e7eb; }
        th { background: #f9fafb; font-weight: 600; color: #374151; }
        tr:hover { background: #fafafa; }
        td { font-size: 0.875rem; vertical-align: top; }
        input[type="text"], textarea, select { width: 100%; padding: 0.25rem 0.5rem; border: 1px solid #d1d5db; border-radius: 0.25rem; font-size: 0.875rem; box-sizing: border-box; }
        input:focus, textarea:focus, select:focus { outline: none; border-color: #0d9488; box-shadow: 0 0 0 2px rgba(13, 148, 136, 0.2); }
        button[type="submit"] { padding: 0.375rem 0.75rem; background: #0d9488; color: #fff; border: none; border-radius: 0.25rem; font-size: 0.75rem; font-weight: 600; cursor: pointer; }
        button[type="submit"]:hover { background: #0f766e; }
        .truncate { max-width: 200px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
        .w-max-400 { max-width: 400px; }
    </style>
</head>
<body>
    <h1>Liste des CourseMusic</h1>

    {% for message in app.flashes('success') %}
        <div class="flash-success">{{ message }}</div>
    {% endfor %}
    {% for message in app.flashes('error') %}
        <div class="flash-error">{{ message }}</div>
    {% endfor %}

    <div style="overflow-x: auto;">
        <table>
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Classe</th>
                    <th>Chapitre</th>
                    <th>Sous-chapitre</th>
                    <th>Actif</th>
                    <th>Prompt · Style · Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for cm in course_musics %}
                    {% set sub = cm.subchapter %}
                    {% set ch = sub ? sub.chapter : null %}
                    {% set subject = ch ? ch.subject : null %}
                    {% set classroom = subject ? subject.classroom : null %}
                    <tr>
                        <td style="font-family: monospace; color: #6b7280;">{{ cm.id }}</td>
                        <td>{{ classroom ? classroom.name : '—' }}</td>
                        <td class="truncate" title="{{ ch ? ch.title : '' }}">{{ ch ? ch.title : '—' }}</td>
                        <td class="truncate" title="{{ sub ? sub.title : '' }}">{{ sub ? sub.title : '—' }}</td>
                        <td>
                            <form action="{{ path('app_course_music_edit', { id: cm.id }) }}" method="post" style="display: flex; flex-direction: column; gap: 0.25rem;">
                                <select name="active">
                                    <option value="" {{ (cm.active ?? '') == '' ? 'selected' : '' }}>—</option>
                                    <option value="active" {{ (cm.active ?? '') == 'active' ? 'selected' : '' }}>Activé</option>
                                    <option value="disabled" {{ (cm.active ?? '') == 'disabled' ? 'selected' : '' }}>Désactivé</option>
                                </select>
                                <button type="submit">Sauvegarder</button>
                            </form>
                        </td>
                        <td class="w-max-400">
                            <form action="{{ path('app_course_music_edit', { id: cm.id }) }}" method="post" style="display: flex; flex-direction: column; gap: 0.5rem;">
                                <textarea name="prompt" rows="3" placeholder="Prompt">{{ cm.prompt ?? '' }}</textarea>
                                <input type="text" name="style" value="{{ cm.style ?? '' }}" placeholder="Style" />
                                <input type="hidden" name="active" value="{{ cm.active ?? '' }}" />
                                <button type="submit">Sauvegarder</button>
                            </form>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="6" style="text-align: center; padding: 2rem; color: #6b7280;">Aucun CourseMusic.</td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</body>
</html>
