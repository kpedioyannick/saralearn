    <Cell><Data ss:Type="String">PHYSIQUE-CHIMIE</Data></Cell>
    <Cell><Data ss:Type="String">La matière à l'échelle microscopique</Data></Cell>
    <Cell><Data ss:Type="String">Cortège électronique de l'atome et classification périodiqueDécouvre comment les électrons s’organisent autour du noyau dans un atome</Data></Cell>
    <Cell><Data ss:Type="String">Cours</Data></Cell>
    <Cell><Data ss:Type="String"></Data></Cell>
    <Cell><Data ss:Type="String">/cours/cortege-electronique-de-l-atome-et-classification-periodique-xec7?srcpath=%2Cfr%2Cannabac%2Cseconde%2Cphysique-chimie%2Cmatiere-echelle-microscopique</Data></Cell>
   </Row>
   <Row>
    <Cell><Data ss:Type="String">Lycée</Data></Cell>
