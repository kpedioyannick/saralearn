   <Row>
    <Cell><Data ss:Type="String">Collège</Data></Cell>
    <Cell><Data ss:Type="String">3ème</Data></Cell>
    <Cell><Data ss:Type="String">SVT</Data></Cell>
    <Cell><Data ss:Type="String">La planète Terre, l'environnement et l'action humaine</Data></Cell>
    <Cell><Data ss:Type="String">L’exploitation des ressources naturelles par l’être humain</Data></Cell>
